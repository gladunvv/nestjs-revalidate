{
  "name": "nestjs-revalidate",
  "version": "0.2.0",
  "description": "Declarative HTTP revalidation for NestJS with ETag, Last-Modified, Cache-Control, Vary and 304 responses.",
  "license": "MIT",
  "author": "Gladun Vladislav <gladun.vladislav@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gladunvv/nestjs-revalidate.git"
  },
  "homepage": "https://github.com/gladunvv/nestjs-revalidate",
  "bugs": {
    "url": "https://github.com/gladunvv/nestjs-revalidate/issues"
  },
  "type": "commonjs",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "nestjs",
    "nest",
    "http",
    "cache",
    "revalidate",
    "revalidation",
    "etag",
    "last-modified",
    "cache-control",
    "conditional-requests",
    "304",
    "not-modified",
    "fastify",
    "express",
    "interceptor",
    "decorators",
    "api",
    "rest"
  ],
  "peerDependencies": {
    "@nestjs/common": "^10.0.0 || ^11.0.0",
    "@nestjs/core": "^10.0.0 || ^11.0.0",
    "reflect-metadata": "^0.1.13 || ^0.2.0",
    "rxjs": "^7.0.0"
  },
  "devDependencies": {
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/platform-fastify": "^11.0.0",
    "@nestjs/testing": "^11.1.19",
    "@types/node": "^22.0.0",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^3.2.4",
    "express": "^5.0.0",
    "fastify": "^5.0.0",
    "supertest": "^7.2.2",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "scripts": {
    "build": "tsup src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run test/unit",
    "test:e2e": "vitest run test/e2e",
    "test:coverage": "vitest run --coverage",
    "prepack": "npm run typecheck && npm run test && npm run build",
    "pack:check": "npm pack --dry-run"
  }
}
